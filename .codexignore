# --- Dependency Managers ---
# Firebase SDKs are massive; exclude them to prevent context window bloat
Pods/
.build/
Carthage/
SourcePackages/

# --- Firebase Specifics ---
# Exclude sensitive config files (AI shouldn't see your API keys/project IDs)
GoogleService-Info.plist
firebase-debug.log

# --- Xcode Metadata & Build Artifacts ---
# DerivedData contains heavy binary artifacts
DerivedData/
*.xcodeproj/project.xcworkspace/
*.xcworkspace/
*.xcuserstate
*.xcuserdatad/

# --- SwiftUI & Previews ---
# Generated by Xcode for canvas previews
Preview Content/

# --- Asset Catalogs ---
# AI cannot "read" images; ignore them to save tokens
*.xcassets/
*.scnassets/

# --- Logs and Temp Files ---
*.log
*.tmp